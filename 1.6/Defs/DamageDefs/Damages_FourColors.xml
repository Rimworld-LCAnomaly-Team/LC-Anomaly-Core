<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Other mods may inherit this base and replace the mod extension. -->
  <DamageDef Name="LC_FourColorDamageBase" Abstract="True">
    <workerClass>LCAnomalyCore.DamageWorker.DamageWorker_FourColor</workerClass>
    <externalViolence>true</externalViolence>
    <hediff>Crush</hediff>
    <hediffSkin>Cut</hediffSkin>
    <hediffSolid>Crack</hediffSolid>
    <impactSoundType>Blunt</impactSoundType>
    <overkillPctToDestroyPart>0.4~1.0</overkillPctToDestroyPart>
  </DamageDef>

  <DamageDef ParentName="LC_FourColorDamageBase">
    <defName>LC_RedDamage</defName>
    <label>RED damage</label>
    <deathMessage>{0} was overwhelmed by physical trauma.</deathMessage>
    <modExtensions>
      <li Class="LCAnomalyCore.ModExtensions.FourColorDamageExtension">
        <damageType>Red</damageType>
      </li>
    </modExtensions>
  </DamageDef>

  <DamageDef ParentName="LC_FourColorDamageBase">
    <defName>LC_WhiteDamage</defName>
    <label>WHITE damage</label>
    <harmsHealth>false</harmsHealth>
    <deathMessage>{0}'s mind was broken.</deathMessage>
    <modExtensions>
      <li Class="LCAnomalyCore.ModExtensions.FourColorDamageExtension">
        <damageType>White</damageType>
      </li>
    </modExtensions>
  </DamageDef>

  <DamageDef ParentName="LC_FourColorDamageBase">
    <defName>LC_BlackDamage</defName>
    <label>BLACK damage</label>
    <deathMessage>{0} succumbed to erosion of body and mind.</deathMessage>
    <modExtensions>
      <li Class="LCAnomalyCore.ModExtensions.FourColorDamageExtension">
        <damageType>Black</damageType>
      </li>
    </modExtensions>
  </DamageDef>

  <DamageDef ParentName="LC_FourColorDamageBase">
    <defName>LC_PaleDamage</defName>
    <label>PALE damage</label>
    <deathMessage>{0}'s soul was extinguished.</deathMessage>
    <modExtensions>
      <li Class="LCAnomalyCore.ModExtensions.FourColorDamageExtension">
        <damageType>Pale</damageType>
      </li>
    </modExtensions>
  </DamageDef>

</Defs>
